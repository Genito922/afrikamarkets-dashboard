# ── Afrika Markets Intelligence — Variables d'environnement ──
# Copier ce fichier en .env et remplir les valeurs

# Base de données PostgreSQL (prod)
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://afrika:change_me_strong_password@localhost:5432/afrikamarkets

# Sécurité JWT
SECRET_KEY=change_me_very_long_random_string_min_32_chars

# Paiements Lemon Squeezy
LEMON_SQUEEZY_KEY=your_lemon_squeezy_api_key
LEMON_SQUEEZY_WEBHOOK_SECRET=your_webhook_secret

# Optionnel — Email reset password (SendGrid / Resend)
EMAIL_API_KEY=your_email_api_key
EMAIL_FROM=noreply@afrikamarkets.io

# Streamlit (dev local)
FASTAPI_URL=http://localhost:8000
